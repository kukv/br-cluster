version: 2
ethernets:
  eth0:
    dhcp4: false
    addresses: [ {{ networks.br_lan.gateway_ip }} ]
wifis:
  renderer: networkd
  wlan0:
    dhcp4: false
    optional: true
    access-points:
      "{{ networks.home_lan.ssid }}":
        password: "{{ networks.home_lan.password }}"
    addresses: [ {{ networks.home_lan.gateway_ip }} ]
    gateway4: {{ networks.home_lan.router_ip }}
    nameservers:
      addresses: [ 8.8.8.8, 8.8.4.4 ]
